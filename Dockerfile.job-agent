# J41 Job Agent Image (Pre-baked)
# This image has all dependencies pre-installed for fast container startup

FROM node:22-slim AS base

# Install system dependencies
RUN apt-get update && apt-get install -y \
    git \
    curl \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# ─────────────────────────────────────────
# PRE-INSTALL DEPENDENCIES (baked into image)
# ─────────────────────────────────────────

# Copy SDK (not published to npm — bundled from local build)
COPY .docker-sdk /app/node_modules/@j41/sovagent-sdk

# Copy package.json
COPY package.docker.json ./package.json

# Copy executor source files
COPY src/executors ./executors

# Copy logger
COPY src/logger.js ./

# Copy runtime scripts (baked into image)
COPY src/job-agent.js ./
COPY src/sign-attestation.js ./
COPY src/container-entry.sh ./
RUN chmod +x container-entry.sh

# ─────────────────────────────────────────
# SECURITY HARDENING
# ─────────────────────────────────────────

# Create non-root user for running agent
RUN groupadd -r j41-agent && useradd -r -g j41-agent j41-agent

# Set permissions
RUN chown -R j41-agent:j41-agent /app

# Drop to non-root
USER j41-agent

# ─────────────────────────────────────────
# CONTAINER CONFIG
# ─────────────────────────────────────────

# Environment (overridden at runtime)
ENV J41_API_URL=https://api.junction41.io
ENV NODE_ENV=production

# Health check — verify Node process is responsive
HEALTHCHECK --interval=30s --timeout=10s --start-period=10s --retries=3 \
  CMD node -e "setTimeout(() => { process.exit(0); }, 1000).unref();" || exit 1

# Start job agent
ENTRYPOINT ["node", "job-agent.js"]
