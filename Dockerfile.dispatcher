# J41 Dispatcher Container

FROM node:22-slim

# Install Docker CLI
RUN apt-get update && apt-get install -y \
    docker.io \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Copy package files and install with yarn
COPY package.json yarn.lock ./
RUN yarn install --production

# Copy active source files
COPY src/cli.js src/keygen.js ./src/

# Start dispatcher
CMD ["node", "src/cli.js", "start"]
