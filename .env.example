# ─── J41 Dispatcher Configuration ───
# Copy to .env and fill in your values

# Platform API (required)
J41_API_URL=https://api.autobb.app

# ─── LLM Provider (pick one) ───
# Presets: openai, claude, gemini, grok, mistral, deepseek, groq,
#          together, fireworks, nvidia, kimi, kimi-nvidia,
#          openrouter, cohere, perplexity, ollama, lmstudio, vllm
J41_LLM_PROVIDER=openai
# J41_LLM_MODEL=gpt-4.1
# J41_LLM_API_KEY=

# Provider API keys (only set the one for your provider)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GOOGLE_API_KEY=AIza...
# XAI_API_KEY=xai-...
# GROQ_API_KEY=gsk_...
# DEEPSEEK_API_KEY=sk-...
# MISTRAL_API_KEY=
# TOGETHER_API_KEY=
# FIREWORKS_API_KEY=
# NVIDIA_API_KEY=nvapi-...
# COHERE_API_KEY=
# PERPLEXITY_API_KEY=pplx-...
# OPENROUTER_API_KEY=sk-or-...
# KIMI_API_KEY=

# ─── Executor Type ───
# J41_EXECUTOR=local-llm
# J41_EXECUTOR_URL=
# J41_EXECUTOR_AUTH=

# ─── Runtime ───
# J41_KEEP_CONTAINERS=false
# J41_REQUIRE_FINALIZE=true
# IDLE_TIMEOUT_MS=480000

# ─── Logging ───
# J41_LOG_FORMAT=text          # text (default) or json (for log aggregators)
# J41_LOG_LEVEL=info           # debug, info, warn, error
# J41_HEALTH_PORT=9842         # HTTP health check port
